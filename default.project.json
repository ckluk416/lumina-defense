{
  "name": "lumina-defense",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Assets": {
        "$className": "Folder",
        "ArcherTower": {
          "$className": "Part",
          "$properties": { "Size": [4, 10, 4], "Color": [1, 0, 0] }
        },
        "LightNode": {
          "$className": "Part",
          "$properties": { "Size": [2, 5, 2], "Color": [1, 1, 0], "Material": "Neon" }
        },
        "BasicEnemy": {
          "$className": "Part",
          "$properties": { "Size": [3, 4, 3], "Color": [0, 1, 0] }
        },
        "Base": {
          "$className": "Part",
          "$properties": { "Size": [10, 5, 10], "Color": [0, 0, 1] }
        }
      },
      "RemoteEvents": {
        "$className": "Folder",
        "RequestPlacement": { "$className": "RemoteEvent" },
        "UpdateMoney": { "$className": "RemoteEvent" }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      },
      "Baseplate": {
        "$className": "Part",
        "$properties": {
          "Anchored": true,
          "Color": [
            0.38823,
            0.37254,
            0.38823
          ],
          "Locked": true,
          "Position": [
            0,
            -10,
            0
          ],
          "Size": [
            512,
            20,
            512
          ]
        }
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}